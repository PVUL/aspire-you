# ── Vite / Frontend ──────────────────────────────────────────────────────────
# Clerk publishable key (safe to expose to client)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Nhost project — use "local" for nhost CLI dev
VITE_NHOST_SUBDOMAIN=local
VITE_NHOST_REGION=

# ── Nhost Serverless Functions (server-side only) ────────────────────────────
# Clerk secret key — used to verify Clerk JWTs
# Set in: nhost/config.yaml (local) or Nhost dashboard → Secrets (cloud)
CLERK_SECRET_KEY=sk_test_...

# Nhost JWT secret — auto-generated by nhost CLI
# NHOST_JWT_SECRET={"type":"HS256","key":"..."}

# ── GitHub OAuth App (direct connection, NOT via Clerk) ──────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps
# Callback URL: http://localhost:1337/v1/functions/github/callback (local dev)
# Set in: nhost/config.yaml (local) or Nhost dashboard → Secrets (cloud)
GITHUB_CLIENT_ID=...
GITHUB_CLIENT_SECRET=...